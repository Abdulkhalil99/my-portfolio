{
  "compilerOptions": {
    "target": "ES2020",
    "types": ["node"],
    "moduleResolution": "node",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "ts-node": {
    "files": true
  },
  "include": ["src/**/*", "prisma/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
